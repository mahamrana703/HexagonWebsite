{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    },
    { 
      "source": "/api/(.*)", 
      "destination": "/api/$1" 
    }
  ],
  "functions": {
    "api/book-demo.js": {
      "runtime": "nodejs18.x"
    }
  }
}
